# Lode environment

# Run the whole app on realistic bundled fixtures, no CLI or funds needed.
# Set to 1 for demo and fresh machines. Leave unset to shell out to byreal-cli.
LODE_MOCK=1

# Anthropic API used by the merchant agent to synthesize Alpha Signals.
# Without it, the merchant falls back to a deterministic local synthesizer.
ANTHROPIC_API_KEY=

# Merchant agent identity. A base58 ed25519 secret. If unset, a demo keypair
# is derived deterministically so the app runs out of the box. For anything
# real, generate one and keep it out of git.
LODE_MERCHANT_SECRET=

# Optional real Solana payment backend (off by default; economy uses mock).
# Set LODE_PAYMENT_BACKEND=solana to enable.
LODE_PAYMENT_BACKEND=mock
SOLANA_RPC_URL=
SOLANA_PRIVATE_KEY=

# Merchant registry. Admin secret gates the approve-merchant endpoint and the
# approve-merchant script; approvals are impossible until it is set. Treasury is
# the pubkey that receives registration fees (defaults to the house merchant
# pubkey if unset).
LODE_ADMIN_SECRET=
NEXT_PUBLIC_LODE_TREASURY=

# Durable store for the registry, ledger, and submitted signals. On Vercel the
# filesystem is ephemeral and per-instance, so set Upstash Redis REST creds for
# data that persists and stays consistent across instances. Without these, the
# app falls back to JSON files under LODE_DATA_DIR (fine for local dev/demo).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Where file-backed data lives when Redis is not configured (defaults to ./data
# locally and a temp dir on Vercel).
LODE_DATA_DIR=
